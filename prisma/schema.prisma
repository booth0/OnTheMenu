generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String           @id @default(uuid())
  username    String           @unique
  email       String?          @unique
  password    String
  role        Role             @default(USER)
  isBanned    Boolean          @default(false)
  banReason   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  images      Image[]
  likes       Like[]
  flags       ModerationFlag[]
  recipes     Recipe[]         @relation("author_recipes")
  recipeBooks RecipeBook[]
  reviews     Review[]         @relation("author_reviews")
  savedRecipes Recipe[]        @relation("saved_recipes")
}

model Recipe {
  id            String           @id @default(uuid())
  slug          String           @unique
  title         String
  description   String?
  ingredients   String[]
  directions    String[]
  visibility          Visibility       @default(PRIVATE)
  forcedPrivate       Boolean          @default(false)
  forcedPrivateReason String?
  featuredImage       String?
  authorId      String
  viewsCount    Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  images        Image[]
  likes         Like[]
  flags         ModerationFlag[]
  author        User             @relation("author_recipes", fields: [authorId], references: [id])
  books         RecipeBookItem[]
  reviews       Review[]
  savedByUsers  User[]           @relation("saved_recipes")
}

model Review {
  id        String           @id @default(uuid())
  recipeId  String
  authorId  String
  rating    Int
  body      String?
  createdAt DateTime         @default(now())
  images    Image[]
  flags     ModerationFlag[]
  author    User             @relation("author_reviews", fields: [authorId], references: [id])
  recipe    Recipe           @relation(fields: [recipeId], references: [id])
}

model Like {
  id        String   @id @default(uuid())
  recipeId  String
  userId    String
  createdAt DateTime @default(now())
  recipe    Recipe   @relation(fields: [recipeId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([recipeId, userId])
}

model Image {
  id           String   @id @default(uuid())
  url          String
  uploadedById String?
  recipeId     String?
  reviewId     String?
  createdAt    DateTime @default(now())
  recipe       Recipe?  @relation(fields: [recipeId], references: [id])
  review       Review?  @relation(fields: [reviewId], references: [id])
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
}

model RecipeBook {
  id          String           @id @default(uuid())
  ownerId     String
  title       String
  description String?
  createdAt   DateTime         @default(now())
  owner       User             @relation(fields: [ownerId], references: [id])
  items       RecipeBookItem[]
}

model RecipeBookItem {
  id       String     @id @default(uuid())
  bookId   String
  recipeId String
  position Int?
  addedAt  DateTime   @default(now())
  book     RecipeBook @relation(fields: [bookId], references: [id])
  recipe   Recipe     @relation(fields: [recipeId], references: [id])

  @@unique([bookId, recipeId])
}

model ModerationFlag {
  id         String     @id @default(uuid())
  reporterId String
  recipeId   String?
  reviewId   String?
  reason     String
  status     FlagStatus @default(OPEN)
  createdAt  DateTime   @default(now())
  reviewedAt DateTime?
  recipe     Recipe?    @relation(fields: [recipeId], references: [id])
  reporter   User       @relation(fields: [reporterId], references: [id])
  review     Review?    @relation(fields: [reviewId], references: [id])
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

enum Visibility {
  PRIVATE
  PUBLIC
}

enum FlagStatus {
  OPEN
  REVIEWED
  CLOSED
}
